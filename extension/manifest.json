{
  "manifest_version": 3,
  "name": "PAMExtensions",
  "description": "증권사 포트폴리오를 스크랩 → 정규화 → 로그인된 SRHFinance 세션으로 업로드하는 MV3 확장.",
  "version": "0.2.0",
  "key": "",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://securities.miraeasset.com/*",
    "https://*.shinhansec.com/*",
    "http://localhost:3000/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "PAMExtensions"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": ["https://securities.miraeasset.com/*"],
      "js": ["src/content/miraeasset/page-bridge.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://securities.miraeasset.com/*"],
      "js": ["src/content/miraeasset/index.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.shinhansec.com/*"],
      "js": ["src/content/shinhan/page-bridge.js"],
      "world": "MAIN",
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://*.shinhansec.com/*"],
      "js": ["src/content/shinhan/index.js"],
      "run_at": "document_idle"
    }
  ]
}
